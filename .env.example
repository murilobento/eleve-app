# Porta da aplicação
PORT=3000

# URL de conexão com o Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# Chave secreta usada pelo Better Auth
BETTER_AUTH_SECRET=troque-por-uma-chave-longa-e-aleatoria

# URL base do Better Auth (normalmente a URL da aplicação)
BETTER_AUTH_URL=http://localhost:3000

# URL pública da aplicação (fallback quando BETTER_AUTH_URL não estiver definido)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# URL pública canônica do site institucional (usada para SEO, sitemap e Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Lista opcional de origens confiáveis adicionais para Better Auth (CSV)
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3001,http://localhost:3002

# Modo da CSP: off, report-only ou enforce
SECURITY_CSP_MODE=off
